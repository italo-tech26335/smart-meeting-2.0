        if (btnSalvar) { btnSalvar.disabled = false; btnSalvar.innerHTML = '<i class="fas fa-save"></i> Salvar'; }
      }
    })
    .withFailureHandler(function(e) {
      toast('Erro: ' + ((e && e.message) || ''), 'erro');
      if (btnSalvar) { btnSalvar.disabled = false; btnSalvar.innerHTML = '<i class="fas fa-save"></i> Salvar'; }
