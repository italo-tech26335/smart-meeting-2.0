async function fluxoSalvarParaDepois(audioBlob, deptInfo, idbIdExistente) {
  if (!audioBlob) { toast('�udio n�o encontrado','erro'); return; }
  const agora = new Date();
  const aaaa  = agora.getFullYear();
  const mm    = String(agora.getMonth()+1).padStart(2,'0');
  const dd    = String(agora.getDate()).padStart(2,'0');
  const hh    = String(agora.getHours()).padStart(2,'0');
  const min   = String(agora.getMinutes()).padStart(2,'0');
  const ss    = String(agora.getSeconds()).padStart(2,'0');
  const ext   = (audioBlob.type||'').includes('mp4') ? 'mp4' : 'webm';
  const deptSlug = ((deptInfo && deptInfo.nome) || 'Dept').replace(/[^a-zA-Z0-9�-�]/g,'_').slice(0,20);
  const nomeArquivo = `${aaaa}-${mm}-${dd}_${deptSlug}_${hh}${min}${ss}.${ext}`;
  const tempId = idbIdExistente || ('tmp_' + Date.now().toString(36));

  try {
    if (!idbIdExistente) {
      await idbSalvar(tempId, audioBlob, { nomeArquivo, deptInfo, timestamp: Date.now() });
      toast('�udio salvo localmente. Enviando para o Drive...', 'info');
    }
    mostrarLoading('Enviando �udio para o Drive...');
    const b64 = await arqParaBase64(audioBlob);
    esconderLoading();

    google.script.run
      .withSuccessHandler(async r => {
        if (r && r.sucesso) {
          await idbRemover(tempId);
          toast('�udio salvo com sucesso!', 'sucesso');
          carregarAudiosNaoProcessados();
          if (!idbIdExistente) limparForm();
          log('SUCESSO', '? �udio salvo: ' + r.nomeArquivo);
        } else {
          toast('Erro ao salvar: ' + ((r && r.mensagem)||'desconhecido'), 'erro');
          log('ERRO', '? ' + ((r && r.mensagem)||'erro ao salvar'));
        }
      })
      .withFailureHandler(e => {
        esconderLoading();
        toast('Falha ao enviar. �udio mantido localmente para reenvio.', 'aviso');
        log('ERRO', '? Falha ao salvar no Drive: ' + ((e && e.message)||''));
      })
      .salvarAudioNaoProcessado(SESSAO_TOKEN, {
        audioBase64:    b64,
        tipoMime:       audioBlob.type || 'audio/webm',
        tamanhoBytes:   audioBlob.size,
        nomeArquivo:    nomeArquivo,
        departamentoId:   (deptInfo && deptInfo.id)   || '',
        departamentoNome: (deptInfo && deptInfo.nome) || '',
        dataGravacao:   agora.toISOString()
      });
  } catch(e) {
    esconderLoading();
    toast('Erro: ' + e.message, 'erro');
    log('ERRO', '? ' + e.message);
  }
}

